@model CompareD.Controllers.FilesSchemaReviewViewModel

@{
    ViewData["Title"] = "שלב 2 — סקירה ומיפוי עמודות";
}

@* ===== מחוון שלבים (Step Indicator) ===== *@
<div class="glass-card mb-5 py-3 px-4" id="step-indicator-bar">
    <div class="d-flex justify-content-center align-items-center gap-2 flex-wrap" id="step-indicator-items">
        <span class="badge bg-success/20 text-success px-3 py-2 fs-6 border border-success/30" id="step-1-badge">✓ 1. העלאת קבצים</span>
        <span class="text-secondary">→</span>
        <span class="badge px-3 py-2 fs-6" style="background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary)); color: #fff;" id="step-2-badge">2. סקירת סכמה ומיפוי</span>
        <span class="text-secondary">→</span>
        <span class="badge bg-dark text-secondary px-3 py-2 fs-6 border border-white/10" id="step-3-badge">3. דוח תוצאות</span>
    </div>
</div>

@* ===== כותרת הדף המרכזית ===== *@
<div class="text-center mb-5" id="csv-review-header">
    <h1 class="display-4 text-gradient mb-3" id="csv-review-title">סקירת מבנה ומיפוי עמודות</h1>
    <p class="lead text-secondary fs-5" id="csv-review-description">
        העמודות מתוך קובצי הנתונים נטענו בהצלחה! הגדירו אילו עמודות ישמשו כמפתח (Key) לזיהוי השורות, ואילו ישמשו להשוואה (Compare).
    </p>
    <div class="d-flex justify-content-center gap-3 mt-3" id="selected-files-preview">
        <span class="badge bg-primary px-3 py-2 fs-6">מקור: @Model.SourceFileName</span>
        <span class="badge bg-secondary px-3 py-2 fs-6" style="background-color: var(--accent-secondary) !important;">יעד: @Model.TargetFileName</span>
    </div>
</div>

@* ===== כרטיס הגדרת כיוון ההשוואה (Source vs Target) ===== *@
<div class="glass-card mb-5 p-4" id="compare-direction-card">
    <h3 class="h5 text-gradient mb-3">הגדרת כיוון ההשוואה</h3>
    <p class="text-secondary small mb-4">
        בחרו איזה מהקבצים שהועלו ישמש כקובץ המקור (Source) ואיזה ישמש כקובץ היעד (Target). שינוי הבחירה יעדכן את כיוון ההשוואה באופן מיידי.
    </p>
    <div class="row g-3 align-items-center justify-content-center">
        <div class="col-md-5">
            <label class="form-label text-secondary small fw-bold">קובץ מקור (Source / Table 1)</label>
            <select id="compare-source-select" class="form-select form-input-glass text-light w-100 cursor-pointer">
                <option value="source" selected>@Model.SourceFileName</option>
                <option value="target">@Model.TargetFileName</option>
            </select>
        </div>
        <div class="col-md-2 text-center fs-3 text-primary pt-3 d-none d-md-block" style="user-select: none;">
            ⇄
        </div>
        <div class="col-md-5">
            <label class="form-label text-secondary small fw-bold">קובץ יעד (Target / Table 2)</label>
            <select id="compare-target-select" class="form-select form-input-glass text-light w-100 cursor-pointer">
                <option value="source">@Model.SourceFileName</option>
                <option value="target" selected>@Model.TargetFileName</option>
            </select>
        </div>
    </div>
</div>

@* ===== הצגת הודעת שגיאה במידה ויש שגיאה בעיבוד ===== *@
@if (TempData["ErrorMessage"] != null)
{
    <div class="glass-card mb-5" style="border-color: rgba(239, 68, 68, 0.3) !important;" id="error-message-box">
        <div class="d-flex align-items-center justify-content-center gap-3">
            <span class="text-danger fw-bold fs-4" style="user-select: none;">✕</span>
            <div class="text-start">
                <h2 class="h6 mb-1 text-danger fw-bold">שגיאה במיפוי</h2>
                <p class="mb-0 text-secondary small">@TempData["ErrorMessage"]</p>
            </div>
        </div>
    </div>
}

<form id="files-compare-exec-form" method="post" asp-controller="Compare" asp-action="RunFilesComparison">
    @Html.AntiForgeryToken()

    @* כרטיס מיפוי עמודות מפורט *@
    <div class="glass-card mb-5" id="columns-mapping-card">
        <h3 class="h4 text-gradient mb-3">הגדרת השוואת עמודות</h3>
        <p class="text-secondary small mb-4">
            סמנו בתיבת הסימון (V) את העמודות שברצונכם לכלול בתהליך. הגדירו את תפקיד העמודה (מפתח מול שדה להשוואה) והתאימו את עמודת היעד.
        </p>

        <div class="table-responsive">
            <table class="table table-dark table-borderless align-middle" id="files-mapping-table">
                <thead>
                    <tr class="text-secondary border-bottom border-white/5 small">
                        <th style="width: 10%;" class="text-center">לכלול?</th>
                        <th style="width: 30%;">עמודת מקור (Table 1)</th>
                        <th style="width: 35%;">עמודת יעד תואמת (Table 2)</th>
                        <th style="width: 25%;">תפקיד העמודה</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var col in Model.SourceColumns)
                    {
                        var isPreChecked = Model.TargetColumns.Any(tc => string.Equals(tc, col, System.StringComparison.OrdinalIgnoreCase));
                        
                        // זיהוי אוטומטי מראש של שדות מפתח מועמדים כדי להקל על המשתמש
                        var isDefaultKey = string.Equals(col, "DAF", StringComparison.OrdinalIgnoreCase) || 
                                           string.Equals(col, "DAF_NOSAF", StringComparison.OrdinalIgnoreCase) || 
                                           string.Equals(col, "RowId", StringComparison.OrdinalIgnoreCase);

                        <tr class="border-bottom border-white/5 py-3">
                            <td class="text-center">
                                <input type="checkbox" name="selectedSourceFields" value="@col" @(isPreChecked ? "checked" : "") class="form-check-input" style="width: 1.4rem; height: 1.4rem; cursor: pointer;" id="check_@col" />
                            </td>
                            <td>
                                <label for="check_@col" class="text-light fw-bold cursor-pointer small">@col</label>
                            </td>
                            <td>
                                <select name="targetMapping_@col" class="form-select form-input-glass text-light w-100" id="target_@col">
                                    <option value="">-- אל תשווה --</option>
                                    @foreach (var targetCol in Model.TargetColumns)
                                    {
                                        if (string.Equals(col, targetCol, System.StringComparison.OrdinalIgnoreCase))
                                        {
                                            <option value="@targetCol" selected>@targetCol</option>
                                        }
                                        else
                                        {
                                            <option value="@targetCol">@targetCol</option>
                                        }
                                    }
                                </select>
                            </td>
                            <td>
                                <select name="roleMapping_@col" class="form-select form-input-glass text-light w-100" id="role_@col">
                                    @if (isDefaultKey)
                                    {
                                        <option value="Compare">שדה להשוואה</option>
                                        <option value="Key" selected>שדה מפתח (Key)</option>
                                    }
                                    else
                                    {
                                        <option value="Compare" selected>שדה להשוואה</option>
                                        <option value="Key">שדה מפתח (Key)</option>
                                    }
                                </select>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* הגדרת כמות שורות מקסימלית להשוואה *@
    <div class="glass-card mb-5 text-center" id="limit-config-container" style="max-width: 450px; margin: 0 auto;">
        <label for="max-rows-input" class="form-label text-secondary fs-6 fw-bold" id="max-rows-label">הגבלת כמות רשומות לטעינה (Max Rows)</label>
        <input type="number" class="form-control form-input-glass text-center text-light mx-auto" id="max-rows-input" name="maxRows" value="1000" min="1" required style="max-width: 200px;" />
        <span class="text-secondary small d-block mt-2">הגבילו את השורות לקבצים גדולים כדי להבטיח ביצועים מהירים.</span>
    </div>

    @* כפתור ביצוע ההשוואה *@
    <div class="text-center" id="action-button-container">
        <button type="submit" class="btn-glow btn-lg px-5 py-3 fs-5" id="btn-run-files-compare">
            הרץ השוואת נתונים
        </button>
        <div class="mt-3">
            <a href="@Url.Action("CompareFilesSetup", "Compare")" class="text-secondary small text-decoration-none">
                ← חזרה להעלאת קבצים
            </a>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // הוספת מאזינים לשינוי כיוון ההשוואה
            const sourceSelect = document.getElementById("compare-source-select");
            const targetSelect = document.getElementById("compare-target-select");

            sourceSelect.addEventListener("change", function() {
                if (sourceSelect.value === "target") {
                    window.location.href = '@Url.Action("SwapFiles", "Compare")';
                }
            });

            targetSelect.addEventListener("change", function() {
                if (targetSelect.value === "source") {
                    window.location.href = '@Url.Action("SwapFiles", "Compare")';
                }
            });

            const checkboxes = document.querySelectorAll('input[name="selectedSourceFields"]');
            checkboxes.forEach(cb => {
                const targetSelect = document.getElementById("target_" + cb.value);
                const roleSelect = document.getElementById("role_" + cb.value);
                
                function updateSelectsState() {
                    if (targetSelect) targetSelect.disabled = !cb.checked;
                    if (roleSelect) roleSelect.disabled = !cb.checked;
                }

                // Initial state
                updateSelectsState();

                // On toggle
                cb.addEventListener("change", updateSelectsState);
            });
        });
    </script>
}
