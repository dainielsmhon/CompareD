@model CompareD.Controllers.SmartComparisonResultViewModel

@{
    ViewData["Title"] = "דוח תוצאות השוואה חכם";
    // חישוב אחוזי התאמה
    int totalProcessedSql = Model.TotalRowsInSql;
    double matchPercentage = totalProcessedSql > 0 
        ? Math.Round((double)Model.TotalMatched / totalProcessedSql * 100, 2) 
        : 100;
}

@* ===== מחוון שלבים (Step Indicator) — שלב 6 פעיל (דוח תוצאות) ===== *@
<div class="glass-card mb-5 py-3 px-4" id="step-indicator-bar">
    <div class="d-flex justify-content-center align-items-center gap-2 flex-wrap" id="step-indicator-items">
        <span class="badge bg-success/20 text-success px-3 py-2 fs-6 border border-success/30" id="step-1-badge">✓ חיבור</span>
        <span class="text-secondary">→</span>
        <span class="badge bg-success/20 text-success px-3 py-2 fs-6 border border-success/30" id="step-2-badge">✓ בחירת טבלה</span>
        <span class="text-secondary">→</span>
        <span class="badge bg-success/20 text-success px-3 py-2 fs-6 border border-success/30" id="step-3-badge">✓ סקירת סכמה</span>
        <span class="text-secondary">→</span>
        <span class="badge px-3 py-2 fs-6" style="background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary)); color: #fff;" id="step-4-badge">דוח תוצאות QA</span>
    </div>
</div>

@* ===== כותרת הדף המרכזית ===== *@
<div class="text-center mb-5" id="results-header">
    <h1 class="display-4 text-gradient mb-3" id="results-title">דוח השוואת נתונים — QA Workflow</h1>
    <p class="lead text-secondary fs-5" id="results-description">
        דוח בדיקות אוטומטי בנוי לפי 3 שלבי אימות סדרתיים: ספירת שורות → מפתחות חסרים → עקביות נתונים.
    </p>
    <div class="d-flex justify-content-center gap-3 mt-3 flex-wrap">
        <span class="badge bg-primary px-3 py-2 fs-6">מקור: @Model.SqlTable</span>
        <span class="badge px-3 py-2 fs-6" style="background-color: var(--accent-secondary) !important;">יעד: @Model.OracleTable</span>
        <span class="badge bg-dark text-light border border-white/10 px-3 py-2 fs-6 font-monospace">מפתח: @Model.PrimaryKeyColumn</span>
    </div>
</div>

@* ===== דשבורד סיכום QA ===== *@
<div class="row g-4 mb-5" id="qa-summary-grid">
    @foreach (var step in Model.QaSteps)
    {
        string badgeClass = step.Status switch
        {
            "Pass" => "bg-success/20 text-success border-success/30",
            "Warning" => "bg-warning/20 text-warning border-warning/30",
            _ => "bg-danger/20 text-danger border-danger/30"
        };
        string icon = step.Status switch
        {
            "Pass" => "✓",
            "Warning" => "⚠",
            _ => "✕"
        };
        <div class="col-md-4">
            <div class="glass-card text-center h-100 py-4" style="border-color: @(step.Status == "Pass" ? "rgba(16,185,129,0.3)" : step.Status == "Warning" ? "rgba(245,158,11,0.3)" : "rgba(239,68,68,0.3)") !important;">
                <span class="badge @badgeClass px-3 py-2 fs-6 border mb-2">@icon שלב @step.StepName</span>
                <h2 class="h6 text-secondary mb-2">@step.StepTitle</h2>
                <div class="text-secondary small px-3">@step.Summary</div>
            </div>
        </div>
    }
</div>

@* =================================================================== *@
@* ===== שלב א: בדיקת שלמות שורות (Row Count Validation) ===== *@
@* =================================================================== *@
<div class="glass-card mb-5 p-4" id="step-a-card">
    <div class="d-flex align-items-center gap-3 mb-4">
        @{
            var stepAData = Model.QaSteps.FirstOrDefault(s => s.StepName == "A");
            string stepABadge = stepAData?.Status == "Pass" ? "bg-success text-white" : "bg-warning text-dark";
            string stepAIcon = stepAData?.Status == "Pass" ? "✓" : "⚠";
        }
        <span class="badge @stepABadge px-3 py-2 fs-5">@stepAIcon</span>
        <h3 class="h4 text-gradient mb-0">שלב א — בדיקת שלמות שורות</h3>
    </div>

    @if (Model.SourceMissingKeysCount > 0 || Model.TargetMissingKeysCount > 0 || Model.SourceDuplicateKeysList.Count > 0 || Model.TargetDuplicateKeysList.Count > 0 || Model.HasRowCountMismatch)
    {
        <div class="p-4 mb-4 rounded-3" style="background: rgba(245, 158, 11, 0.1); border: 1px solid rgba(245, 158, 11, 0.3);">
            <div class="d-flex align-items-center gap-3">
                <span class="fs-2">⚠</span>
                <div>
                    <h4 class="h6 text-warning fw-bold mb-1">פערים ואזהרות בשלמות השורות והמפתחות</h4>
                    <p class="text-secondary small mb-0">@stepAData?.Summary</p>
                </div>
            </div>
        </div>
    }

    <div class="row g-4">
        @* צד מקור *@
        <div class="col-md-6">
            <div class="p-4 rounded-3 h-100" style="background: rgba(15, 23, 42, 0.4); border: 1px solid var(--border-color);">
                <h4 class="h5 text-primary mb-3">מקור (@Model.SqlTable)</h4>
                
                <div class="list-group list-group-flush bg-transparent">
                    <div class="list-group-item bg-transparent d-flex justify-content-between align-items-center border-white/5 px-0 py-2">
                        <span class="text-secondary small">ספירת שורות גולמית (Raw Count)</span>
                        <span class="badge bg-primary fs-6">@Model.SourceRawCount</span>
                    </div>
                    <div class="list-group-item bg-transparent d-flex justify-content-between align-items-center border-white/5 px-0 py-2">
                        <span class="text-secondary small">מפתחות ייחודיים תקינים (Unique Valid Keys)</span>
                        <span class="badge bg-success/20 text-success border border-success/30 fs-6">@Model.SourceUniqueValidKeys</span>
                    </div>
                    <div class="list-group-item bg-transparent d-flex justify-content-between align-items-center border-white/5 px-0 py-2">
                        <span class="text-secondary small">מפתחות כפולים (Duplicate Keys)</span>
                        <span class="badge @(Model.SourceDuplicateKeysCount > 0 ? "bg-danger/20 text-danger border border-danger/30" : "bg-secondary/20 text-secondary border border-secondary/30") fs-6">@Model.SourceDuplicateKeysCount</span>
                    </div>
                    <div class="list-group-item bg-transparent d-flex justify-content-between align-items-center border-white/5 px-0 py-2">
                        <span class="text-secondary small">מפתחות חסרים (Missing Keys)</span>
                        <span class="badge @(Model.SourceMissingKeysCount > 0 ? "bg-warning/20 text-warning border border-warning/30" : "bg-secondary/20 text-secondary border border-secondary/30") fs-6">@Model.SourceMissingKeysCount</span>
                    </div>
                </div>

                @if (Model.SourceDuplicateKeysList.Count > 0)
                {
                    <div class="mt-3">
                        <span class="text-danger small fw-bold d-block mb-1">דוגמאות למפתחות כפולים במקור:</span>
                        <div class="d-flex flex-wrap gap-1">
                            @foreach (var k in Model.SourceDuplicateKeysList.Take(4))
                            {
                                <span class="badge bg-danger/10 text-danger border border-danger/20 font-monospace py-1 px-2 small">@k</span>
                            }
                        </div>
                        @if (Model.SourceDuplicateKeysList.Count > 4)
                        {
                            <span class="text-secondary small d-block mt-1">מציג 4 מתוך @Model.SourceDuplicateKeysList.Count מפתחות כפולים.</span>
                        }
                    </div>
                }

                @if (Model.SourceMissingKeysList.Count > 0)
                {
                    <div class="mt-3">
                        <span class="text-warning small fw-bold d-block mb-1">דוגמאות למפתחות חסרים במקור (קיימים רק ביעד):</span>
                        <div class="d-flex flex-wrap gap-1">
                            @foreach (var k in Model.SourceMissingKeysList.Take(4))
                            {
                                <span class="badge bg-warning/10 text-warning border border-warning/20 font-monospace py-1 px-2 small">@k</span>
                            }
                        </div>
                        @if (Model.SourceMissingKeysList.Count > 4)
                        {
                            <span class="text-secondary small d-block mt-1">מציג 4 מתוך @Model.SourceMissingKeysList.Count מפתחות חסרים.</span>
                        }
                    </div>
                }
            </div>
        </div>

        @* צד יעד *@
        <div class="col-md-6">
            <div class="p-4 rounded-3 h-100" style="background: rgba(15, 23, 42, 0.4); border: 1px solid var(--border-color);">
                <h4 class="h5 mb-3" style="color: var(--accent-secondary);">יעד (@Model.OracleTable)</h4>
                
                <div class="list-group list-group-flush bg-transparent">
                    <div class="list-group-item bg-transparent d-flex justify-content-between align-items-center border-white/5 px-0 py-2">
                        <span class="text-secondary small">ספירת שורות גולמית (Raw Count)</span>
                        <span class="badge fs-6" style="background-color: var(--accent-secondary) !important;">@Model.TargetRawCount</span>
                    </div>
                    <div class="list-group-item bg-transparent d-flex justify-content-between align-items-center border-white/5 px-0 py-2">
                        <span class="text-secondary small">מפתחות ייחודיים תקינים (Unique Valid Keys)</span>
                        <span class="badge bg-success/20 text-success border border-success/30 fs-6">@Model.TargetUniqueValidKeys</span>
                    </div>
                    <div class="list-group-item bg-transparent d-flex justify-content-between align-items-center border-white/5 px-0 py-2">
                        <span class="text-secondary small">מפתחות כפולים (Duplicate Keys)</span>
                        <span class="badge @(Model.TargetDuplicateKeysCount > 0 ? "bg-danger/20 text-danger border border-danger/30" : "bg-secondary/20 text-secondary border border-secondary/30") fs-6">@Model.TargetDuplicateKeysCount</span>
                    </div>
                    <div class="list-group-item bg-transparent d-flex justify-content-between align-items-center border-white/5 px-0 py-2">
                        <span class="text-secondary small">מפתחות חסרים (Missing Keys)</span>
                        <span class="badge @(Model.TargetMissingKeysCount > 0 ? "bg-warning/20 text-warning border border-warning/30" : "bg-secondary/20 text-secondary border border-secondary/30") fs-6">@Model.TargetMissingKeysCount</span>
                    </div>
                </div>

                @if (Model.TargetDuplicateKeysList.Count > 0)
                {
                    <div class="mt-3">
                        <span class="text-danger small fw-bold d-block mb-1">דוגמאות למפתחות כפולים ביעד:</span>
                        <div class="d-flex flex-wrap gap-1">
                            @foreach (var k in Model.TargetDuplicateKeysList.Take(4))
                            {
                                <span class="badge bg-danger/10 text-danger border border-danger/20 font-monospace py-1 px-2 small">@k</span>
                            }
                        </div>
                        @if (Model.TargetDuplicateKeysList.Count > 4)
                        {
                            <span class="text-secondary small d-block mt-1">מציג 4 מתוך @Model.TargetDuplicateKeysList.Count מפתחות כפולים.</span>
                        }
                    </div>
                }

                @if (Model.TargetMissingKeysList.Count > 0)
                {
                    <div class="mt-3">
                        <span class="text-warning small fw-bold d-block mb-1">דוגמאות למפתחות חסרים ביעד (קיימים רק במקור):</span>
                        <div class="d-flex flex-wrap gap-1">
                            @foreach (var k in Model.TargetMissingKeysList.Take(4))
                            {
                                <span class="badge bg-warning/10 text-warning border border-warning/20 font-monospace py-1 px-2 small">@k</span>
                            }
                        </div>
                        @if (Model.TargetMissingKeysList.Count > 4)
                        {
                            <span class="text-secondary small d-block mt-1">מציג 4 מתוך @Model.TargetMissingKeysList.Count מפתחות חסרים.</span>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* =================================================================== *@
@* ===== שלב ב: זיהוי מפתחות חסרים (Primary Key Validation) ===== *@
@* =================================================================== *@
<div class="glass-card mb-5 p-4" id="step-b-card">
    <div class="d-flex align-items-center gap-3 mb-4">
        @{
            var stepBData = Model.QaSteps.FirstOrDefault(s => s.StepName == "B");
            string stepBBadge = stepBData?.Status == "Pass" ? "bg-success text-white" : stepBData?.Status == "Warning" ? "bg-warning text-dark" : "bg-danger text-white";
            string stepBIcon = stepBData?.Status == "Pass" ? "✓" : stepBData?.Status == "Warning" ? "⚠" : "✕";
        }
        <span class="badge @stepBBadge px-3 py-2 fs-5">@stepBIcon</span>
        <h3 class="h4 text-gradient mb-0">שלב ב — זיהוי מפתחות חסרים</h3>
    </div>

    <div class="row g-4 mb-4">
        @* כרטיס חסרים ביעד *@
        <div class="col-md-4">
            <div class="p-3 rounded-3 text-center h-100" style="background: rgba(15, 23, 42, 0.4); border: 1px solid @(Model.TotalMissingInOracle > 0 ? "rgba(245,158,11,0.3)" : "var(--border-color)");">
                <div class="text-secondary small mb-1">חסר ביעד (@Model.OracleTable)</div>
                <div class="display-6 fw-bold @(Model.TotalMissingInOracle > 0 ? "text-warning" : "text-success")">@Model.TotalMissingInOracle</div>
            </div>
        </div>
        @* כרטיס חסרים במקור *@
        <div class="col-md-4">
            <div class="p-3 rounded-3 text-center h-100" style="background: rgba(15, 23, 42, 0.4); border: 1px solid @(Model.TotalMissingInSql > 0 ? "rgba(59,130,246,0.3)" : "var(--border-color)");">
                <div class="text-secondary small mb-1">חסר במקור (@Model.SqlTable)</div>
                <div class="display-6 fw-bold @(Model.TotalMissingInSql > 0 ? "text-primary" : "text-success")">@Model.TotalMissingInSql</div>
            </div>
        </div>
        @* כרטיס כפילויות *@
        <div class="col-md-4">
            <div class="p-3 rounded-3 text-center h-100" style="background: rgba(15, 23, 42, 0.4); border: 1px solid @(Model.TotalDuplicates > 0 ? "rgba(139,92,246,0.3)" : "var(--border-color)");">
                <div class="text-secondary small mb-1">כפילויות מפתח (הוחרגו)</div>
                <div class="display-6 fw-bold @(Model.TotalDuplicates > 0 ? "text-info" : "text-success")">@Model.TotalDuplicates</div>
            </div>
        </div>
    </div>

    @* רשימות מפתחות חסרים *@
    @if (Model.TotalMissingInOracle > 0 || Model.TotalMissingInSql > 0)
    {
        <div class="row g-4 mb-4">
            @if (Model.TotalMissingInOracle > 0)
            {
                <div class="col-md-6">
                    <h5 class="h6 text-warning mb-2">מפתחות חסרים ביעד (@Model.OracleTable):</h5>
                    <div class="list-group list-group-flush border-white/5" style="max-height: 300px; overflow-y: auto;">
                        @foreach (var key in Model.MissingInOracle)
                        {
                            <div class="list-group-item bg-transparent text-light border-bottom border-white/5 font-monospace py-2 small">
                                @key
                            </div>
                        }
                    </div>
                    @if (Model.TotalMissingInOracle > 50)
                    {
                        <span class="text-secondary small d-block mt-2">מציג 50 רשומות ראשונות מתוך @Model.TotalMissingInOracle.</span>
                    }
                </div>
            }
            @if (Model.TotalMissingInSql > 0)
            {
                <div class="col-md-6">
                    <h5 class="h6 text-primary mb-2">מפתחות חסרים במקור (@Model.SqlTable):</h5>
                    <div class="list-group list-group-flush border-white/5" style="max-height: 300px; overflow-y: auto;">
                        @foreach (var key in Model.MissingInSql)
                        {
                            <div class="list-group-item bg-transparent text-light border-bottom border-white/5 font-monospace py-2 small">
                                @key
                            </div>
                        }
                    </div>
                    @if (Model.TotalMissingInSql > 50)
                    {
                        <span class="text-secondary small d-block mt-2">מציג 50 רשומות ראשונות מתוך @Model.TotalMissingInSql.</span>
                    }
                </div>
            }
        </div>
    }

    @* טבלת כפילויות מפתח *@
    @if (Model.Duplicates.Count > 0)
    {
        <h5 class="h6 text-info mb-2">כפילויות מפתח שהוחרגו (@Model.Duplicates.Count):</h5>
        <div class="table-responsive">
            <table class="table table-dark table-sm table-borderless align-middle">
                <thead>
                    <tr class="text-secondary small border-bottom border-white/5">
                        <th style="width: 50%;">ערך מפתח כפול</th>
                        <th style="width: 25%;" class="text-center">מופעים במקור</th>
                        <th style="width: 25%;" class="text-center">מופעים ביעד</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dup in Model.Duplicates)
                    {
                        <tr class="border-bottom border-white/5">
                            <td class="font-monospace text-light small">@dup.KeyValue</td>
                            <td class="text-center @(dup.SqlCount > 1 ? "text-warning fw-bold" : "")">@dup.SqlCount</td>
                            <td class="text-center @(dup.OracleCount > 1 ? "text-warning fw-bold" : "")">@dup.OracleCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (Model.TotalMissingInOracle == 0 && Model.TotalMissingInSql == 0 && Model.Duplicates.Count == 0)
    {
        <div class="text-center py-3 text-success">
            <span class="fs-2 d-block mb-2">✓</span>
            <h5 class="fw-bold">כל המפתחות קיימים בשני הצדדים ואין כפילויות!</h5>
        </div>
    }
</div>

@* =================================================================== *@
@* ===== שלב ג: ניתוח עקביות נתונים (Data Consistency Check) ===== *@
@* =================================================================== *@
<div class="glass-card mb-5 p-4" id="step-c-card">
    <div class="d-flex align-items-center gap-3 mb-4">
        @{
            var stepCData = Model.QaSteps.FirstOrDefault(s => s.StepName == "C");
            string stepCBadge = stepCData?.Status == "Pass" ? "bg-success text-white" : "bg-danger text-white";
            string stepCIcon = stepCData?.Status == "Pass" ? "✓" : "✕";
        }
        <span class="badge @stepCBadge px-3 py-2 fs-5">@stepCIcon</span>
        <h3 class="h4 text-gradient mb-0">שלב ג — ניתוח עקביות נתונים</h3>
    </div>

    @* סיכום שורות תואמות *@
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="p-3 rounded-3 text-center" style="background: rgba(15, 23, 42, 0.4); border: 1px solid rgba(16, 185, 129, 0.3);">
                <div class="text-secondary small mb-1">רשומות זהות</div>
                <div class="display-6 fw-bold text-success">@Model.TotalMatched</div>
                <span class="badge bg-success/10 text-success mt-1">@matchPercentage% תאימות</span>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 rounded-3 text-center" style="background: rgba(15, 23, 42, 0.4); border: 1px solid @(Model.TotalDiscrepancyRows > 0 ? "rgba(239,68,68,0.3)" : "var(--border-color)");">
                <div class="text-secondary small mb-1">שורות עם הפרשי ערכים</div>
                <div class="display-6 fw-bold @(Model.TotalDiscrepancyRows > 0 ? "text-danger" : "text-success")">@Model.TotalDiscrepancyRows</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 rounded-3 text-center" style="background: rgba(15, 23, 42, 0.4); border: 1px solid @(Model.DataIntegrityGaps.Count > 0 ? "rgba(245,158,11,0.3)" : "var(--border-color)");">
                <div class="text-secondary small mb-1">פערי שלמות (ערך מול ריק/אפס)</div>
                <div class="display-6 fw-bold @(Model.DataIntegrityGaps.Count > 0 ? "text-warning" : "text-success")">@Model.DataIntegrityGaps.Count</div>
            </div>
        </div>
    </div>

    @* תבניות הבדלי נתונים *@
    @if (Model.DiscrepancyPatterns.Count > 0)
    {
        <h5 class="h6 text-gradient mb-3">תבניות הבדלי נתונים (@Model.DiscrepancyPatterns.Count תבניות):</h5>
        <div class="accordion accordion-flush mb-4" id="patternsAccordion">
            @for (int i = 0; i < Model.DiscrepancyPatterns.Count; i++)
            {
                var pattern = Model.DiscrepancyPatterns[i];
                double percentage = Model.TotalDiscrepancyRows > 0 
                    ? Math.Round((double)pattern.Count / Model.TotalDiscrepancyRows * 100, 1) 
                    : 0;

                <div class="accordion-item bg-transparent border-bottom border-white/5 mb-3" style="border: 1px solid rgba(255,255,255,0.05); border-radius: 8px; overflow: hidden; background: rgba(255,255,255,0.01);">
                    <h2 class="accordion-header" id="heading-@i">
                        <button class="accordion-button collapsed bg-transparent text-light py-3 px-4 d-flex justify-content-between align-items-center" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@i" aria-expanded="false" aria-controls="collapse-@i" style="box-shadow: none;">
                            <div class="d-flex align-items-center gap-3 w-100 justify-content-between pe-3">
                                <span class="fw-bold text-light">@pattern.PatternDescription</span>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="badge bg-danger/10 text-danger border border-danger/20 px-3 py-2 fs-7">
                                        @pattern.Count שורות
                                    </span>
                                    <span class="badge bg-secondary/20 text-secondary border border-white/10 px-2 py-2 small">
                                        שכיחות: @percentage%
                                    </span>
                                </div>
                            </div>
                        </button>
                    </h2>
                    <div id="collapse-@i" class="accordion-collapse collapse" aria-labelledby="heading-@i" data-bs-parent="#patternsAccordion">
                        <div class="accordion-body p-4 border-top border-white/5" style="background: rgba(0,0,0,0.2);">
                            
                            @* טבלת הערכים והשוואת השדות בתבנית *@
                            <h5 class="h6 text-gradient mb-3">ערכים לדוגמה ושדות שונים:</h5>
                            <div class="table-responsive mb-4">
                                <table class="table table-dark table-sm table-borderless align-middle">
                                    <thead>
                                        <tr class="text-secondary border-bottom border-white/5 small">
                                            <th style="width: 30%;">שם שדה</th>
                                            <th style="width: 35%;">ערך במקור (@Model.SqlTable)</th>
                                            <th style="width: 35%;">ערך ביעד (@Model.OracleTable)</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var field in pattern.Fields)
                                        {
                                            <tr class="border-bottom border-white/5">
                                                <td class="text-secondary small fw-bold">@field.FieldName</td>
                                                <td class="text-danger font-monospace">@field.SqlValue</td>
                                                <td class="text-danger font-monospace">@field.OracleValue</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            @* הצגת מפתחות לדוגמה *@
                            <h5 class="h6 text-gradient mb-2">מפתחות שורה לדוגמה (עד 4 מפתחות):</h5>
                            <div class="d-flex gap-2 flex-wrap">
                                @foreach (var key in pattern.ExampleKeys)
                                {
                                    <span class="badge bg-dark text-light border border-white/10 px-3 py-2 font-monospace">
                                        @key
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else if (Model.TotalDiscrepancyRows == 0)
    {
        <div class="text-center py-3 text-success mb-4">
            <span class="fs-2 d-block mb-2">✓</span>
            <h5 class="fw-bold">אין הבדלי נתונים!</h5>
            <p class="text-secondary mb-0">כל הרשומות המשותפות שנבדקו תואמות לחלוטין.</p>
        </div>
    }

    @* פערי שלמות נתונים (Data Integrity Gaps) *@
    @if (Model.DataIntegrityGaps.Count > 0)
    {
        <h5 class="h6 text-gradient mb-3">פערי שלמות נתונים — ערך מול ריק/אפס (@Model.DataIntegrityGaps.Count ממצאים):</h5>
        <p class="text-secondary small mb-3">
            מקרים בהם ערך קיים בצד אחד אך בצד השני הוא ריק, null, או 0. ממצאים אלו מעידים על בעיית שלמות נתונים.
        </p>
        <div class="table-responsive">
            <table class="table table-dark table-sm table-borderless align-middle">
                <thead>
                    <tr class="text-secondary border-bottom border-white/5 small">
                        <th style="width: 25%;">ערך מפתח</th>
                        <th style="width: 30%;">שם שדה</th>
                        <th style="width: 20%;">צד עם ערך</th>
                        <th style="width: 25%;">הערך שנמצא</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var gap in Model.DataIntegrityGaps.Take(100))
                    {
                        <tr class="border-bottom border-white/5">
                            <td class="font-monospace text-light small">@gap.KeyValue</td>
                            <td class="text-secondary small fw-bold">@gap.FieldName</td>
                            <td>
                                @if (gap.PresentSide == "Source")
                                {
                                    <span class="badge bg-primary/10 text-primary border border-primary/20 px-2 py-1 small">מקור</span>
                                }
                                else
                                {
                                    <span class="badge bg-info/10 text-info border border-info/20 px-2 py-1 small">יעד</span>
                                }
                            </td>
                            <td class="text-warning font-monospace small">@gap.PresentValue</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (Model.DataIntegrityGaps.Count > 100)
        {
            <span class="text-secondary small d-block mt-2">מציג 100 ממצאים ראשונים מתוך @Model.DataIntegrityGaps.Count.</span>
        }
    }
</div>

@* ===== כפתורי פעולה — ייצוא וחזרה ===== *@
<div class="text-center mb-5 d-flex justify-content-center align-items-center gap-3 flex-wrap" id="restart-action-container">
    <button type="button" onclick="exportToExcel()" class="btn btn-outline-success btn-lg px-4 py-3 fs-5 d-flex align-items-center gap-2" id="btn-export-excel" style="border-radius: 0.75rem;">
        📊 ייצוא לאקסל (Excel)
    </button>
    <button type="button" onclick="exportToWord()" class="btn btn-outline-info btn-lg px-4 py-3 fs-5 d-flex align-items-center gap-2" id="btn-export-word" style="border-radius: 0.75rem;">
        📝 ייצוא לוורד (Word)
    </button>
    <a asp-controller="Home" asp-action="Index" class="btn-glow btn-lg text-decoration-none px-5 py-3 fs-5" id="btn-restart-compare">
        התחל השוואה חדשה
    </a>
</div>

@section Scripts {
    <script>
        // Serialize model for JavaScript export functions
        const model = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));

        function exportToExcel() {
            let csv = "";
            csv += "דוח השוואת נתונים — QA Workflow\n";
            csv += `מקור,${model.SqlTable}\n`;
            csv += `יעד,${model.OracleTable}\n`;
            csv += `מפתח השוואה,${model.PrimaryKeyColumn}\n\n`;

            // Step A
            csv += "=== שלב א: בדיקת שלמות שורות ===\n";
            csv += "מדד,מקור,יעד\n";
            csv += `ספירת שורות גולמית (Raw Count),${model.SourceRawCount},${model.TargetRawCount}\n`;
            csv += `מפתחות ייחודיים תקינים (Unique Valid Keys),${model.SourceUniqueValidKeys},${model.TargetUniqueValidKeys}\n`;
            csv += `מפתחות כפולים (Duplicate Keys Count),${model.SourceDuplicateKeysCount},${model.TargetDuplicateKeysCount}\n`;
            csv += `מפתחות חסרים (Missing Keys Count),${model.SourceMissingKeysCount},${model.TargetMissingKeysCount}\n\n`;

            if (model.SourceDuplicateKeysList.length > 0) {
                csv += "מפתחות כפולים במקור\n";
                model.SourceDuplicateKeysList.forEach(k => { csv += `"${k}"\n`; });
                csv += "\n";
            }
            if (model.TargetDuplicateKeysList.length > 0) {
                csv += "מפתחות כפולים ביעד\n";
                model.TargetDuplicateKeysList.forEach(k => { csv += `"${k}"\n`; });
                csv += "\n";
            }
            if (model.SourceMissingKeysList.length > 0) {
                csv += "מפתחות חסרים במקור\n";
                model.SourceMissingKeysList.forEach(k => { csv += `"${k}"\n`; });
                csv += "\n";
            }
            if (model.TargetMissingKeysList.length > 0) {
                csv += "מפתחות חסרים ביעד\n";
                model.TargetMissingKeysList.forEach(k => { csv += `"${k}"\n`; });
                csv += "\n";
            }

            // Step B
            csv += "=== שלב ב: זיהוי מפתחות חסרים ===\n";
            csv += `חסר ביעד,${model.TotalMissingInOracle}\n`;
            csv += `חסר במקור,${model.TotalMissingInSql}\n`;
            csv += `כפילויות מפתח,${model.TotalDuplicates}\n\n`;

            if (model.MissingInOracle.length > 0) {
                csv += "מפתחות חסרים ביעד (מתוך שלב ב)\n";
                model.MissingInOracle.forEach(k => { csv += `"${k}"\n`; });
                csv += "\n";
            }

            if (model.MissingInSql.length > 0) {
                csv += "מפתחות חסרים במקור (מתוך שלב ב)\n";
                model.MissingInSql.forEach(k => { csv += `"${k}"\n`; });
                csv += "\n";
            }

            if (model.Duplicates.length > 0) {
                csv += "כפילויות מפתח (מתוך שלב ב)\n";
                csv += "ערך מפתח,כמות במקור,כמות ביעד\n";
                model.Duplicates.forEach(d => {
                    csv += `"${d.KeyValue}",${d.SqlCount},${d.OracleCount}\n`;
                });
                csv += "\n";
            }

            // Step C
            csv += "=== שלב ג: ניתוח עקביות נתונים ===\n";
            csv += `רשומות זהות,${model.TotalMatched}\n`;
            csv += `הפרשי ערכים,${model.TotalDiscrepancyRows}\n`;
            csv += `פערי שלמות,${model.DataIntegrityGaps.length}\n\n`;

            if (model.DiscrepancyPatterns.length > 0) {
                csv += "תבניות הבדלים\n";
                csv += "תיאור תבנית,כמות שורות,מפתחות לדוגמה,שדה,ערך במקור,ערך ביעד\n";
                model.DiscrepancyPatterns.forEach(p => {
                    const keys = p.ExampleKeys.join(" | ");
                    p.Fields.forEach((f, idx) => {
                        const desc = idx === 0 ? `"${p.PatternDescription}"` : "";
                        const count = idx === 0 ? p.Count : "";
                        const keysShow = idx === 0 ? `"${keys}"` : "";
                        csv += `${desc},${count},${keysShow},"${f.FieldName}","${f.SqlValue}","${f.OracleValue}"\n`;
                    });
                });
                csv += "\n";
            }

            if (model.DataIntegrityGaps.length > 0) {
                csv += "פערי שלמות נתונים\n";
                csv += "ערך מפתח,שם שדה,צד עם ערך,הערך שנמצא\n";
                model.DataIntegrityGaps.forEach(g => {
                    csv += `"${g.KeyValue}","${g.FieldName}","${g.PresentSide === 'Source' ? 'מקור' : 'יעד'}","${g.PresentValue}"\n`;
                });
            }

            const blob = new Blob(["\uFEFF" + csv], { type: "text/csv;charset=utf-8;" });
            const link = document.createElement("a");
            link.href = URL.createObjectURL(blob);
            link.download = `QA_Report_${model.SqlTable}_vs_${model.OracleTable}.csv`;
            link.click();
        }

        function exportToWord() {
            const stepAStatus = (model.SourceMissingKeysCount > 0 || model.TargetMissingKeysCount > 0 || model.SourceDuplicateKeysList.length > 0 || model.TargetDuplicateKeysList.length > 0 || model.HasRowCountMismatch)
                ? '<span style="color:orange; font-weight:bold;">⚠ פערים בשלמות</span>' 
                : '<span style="color:green; font-weight:bold;">✓ שלמות תקינה</span>';
            
            let html = `
            <html dir="rtl" lang="he">
            <head>
                <meta charset="utf-8">
                <style>
                    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; text-align: right; }
                    h1 { color: #1e3a8a; border-bottom: 2px solid #1e3a8a; padding-bottom: 10px; text-align: center; }
                    h2 { color: #2563eb; margin-top: 30px; border-bottom: 1px solid #ddd; padding-bottom: 5px; }
                    h3 { color: #374151; margin-top: 20px; }
                    table { width: 100%; border-collapse: collapse; margin-top: 15px; margin-bottom: 15px; direction: rtl; }
                    th, td { border: 1px solid #ddd; padding: 10px; text-align: right; }
                    th { background-color: #f3f4f6; color: #1f2937; }
                    .mono { font-family: Consolas, monospace; }
                    .text-center { text-align: center; }
                    .warning-box { background: #fff3cd; border: 1px solid #ffc107; border-radius: 8px; padding: 15px; margin: 15px 0; }
                    .pass-box { background: #d1fae5; border: 1px solid #10b981; border-radius: 8px; padding: 15px; margin: 15px 0; }
                </style>
            </head>
            <body>
                <h1>דוח השוואת נתונים — QA Workflow</h1>
                <p><strong>מקור:</strong> ${model.SqlTable}</p>
                <p><strong>יעד:</strong> ${model.OracleTable}</p>
                <p><strong>מפתח השוואה:</strong> ${model.PrimaryKeyColumn}</p>
                <p><strong>תאריך הפקה:</strong> ${new Date().toLocaleString('he-IL')}</p>

                <h2>שלב א — בדיקת שלמות שורות</h2>
                <p><strong>סטטוס:</strong> ${stepAStatus}</p>
                <table>
                    <thead>
                        <tr>
                            <th>מדד</th>
                            <th>מקור (${model.SqlTable})</th>
                            <th>יעד (${model.OracleTable})</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>ספירת שורות גולמית (Raw Count)</td>
                            <td class="text-center">${model.SourceRawCount}</td>
                            <td class="text-center">${model.TargetRawCount}</td>
                        </tr>
                        <tr>
                            <td>מפתחות ייחודיים תקינים (Unique Valid Keys)</td>
                            <td class="text-center">${model.SourceUniqueValidKeys}</td>
                            <td class="text-center">${model.TargetUniqueValidKeys}</td>
                        </tr>
                        <tr>
                            <td>מפתחות כפולים (Duplicate Keys Count)</td>
                            <td class="text-center">${model.SourceDuplicateKeysCount}</td>
                            <td class="text-center">${model.TargetDuplicateKeysCount}</td>
                        </tr>
                        <tr>
                            <td>מפתחות חסרים (Missing Keys Count)</td>
                            <td class="text-center">${model.SourceMissingKeysCount}</td>
                            <td class="text-center">${model.TargetMissingKeysCount}</td>
                        </tr>
                    </tbody>
                </table>
            `;

            if (model.SourceDuplicateKeysList.length > 0) {
                html += `<h3>מפתחות כפולים במקור (${model.SourceDuplicateKeysList.length})</h3><ul>`;
                model.SourceDuplicateKeysList.forEach(k => { html += `<li class="mono">${k}</li>`; });
                html += "</ul>";
            }

            if (model.TargetDuplicateKeysList.length > 0) {
                html += `<h3>מפתחות כפולים ביעד (${model.TargetDuplicateKeysList.length})</h3><ul>`;
                model.TargetDuplicateKeysList.forEach(k => { html += `<li class="mono">${k}</li>`; });
                html += "</ul>";
            }

            if (model.SourceMissingKeysList.length > 0) {
                html += `<h3>מפתחות חסרים במקור (${model.SourceMissingKeysList.length})</h3><ul>`;
                model.SourceMissingKeysList.forEach(k => { html += `<li class="mono">${k}</li>`; });
                html += "</ul>";
            }

            if (model.TargetMissingKeysList.length > 0) {
                html += `<h3>מפתחות חסרים ביעד (${model.TargetMissingKeysList.length})</h3><ul>`;
                model.TargetMissingKeysList.forEach(k => { html += `<li class="mono">${k}</li>`; });
                html += "</ul>";
            }

            html += `
                <h2>שלב ב — זיהוי מפתחות חסרים</h2>
                <table>
                    <tr><th>קטגוריה</th><th>כמות</th></tr>
                    <tr><td>חסר ביעד</td><td style="color: orange; font-weight: bold;">${model.TotalMissingInOracle}</td></tr>
                    <tr><td>חסר במקור</td><td style="color: blue; font-weight: bold;">${model.TotalMissingInSql}</td></tr>
                    <tr><td>כפילויות מפתח</td><td>${model.TotalDuplicates}</td></tr>
                </table>
            `;

            if (model.MissingInOracle.length > 0) {
                html += `<h3>מפתחות חסרים ביעד (${model.TotalMissingInOracle})</h3><ul>`;
                model.MissingInOracle.forEach(k => { html += `<li class="mono">${k}</li>`; });
                html += "</ul>";
            }

            if (model.MissingInSql.length > 0) {
                html += `<h3>מפתחות חסרים במקור (${model.TotalMissingInSql})</h3><ul>`;
                model.MissingInSql.forEach(k => { html += `<li class="mono">${k}</li>`; });
                html += "</ul>";
            }

            html += `
                <h2>שלב ג — ניתוח עקביות נתונים</h2>
                <table>
                    <tr><th>קטגוריה</th><th>כמות</th><th>פירוט</th></tr>
                    <tr><td>רשומות זהות</td><td style="color: green; font-weight: bold;">${model.TotalMatched}</td><td>${(model.TotalRowsInSql > 0 ? (model.TotalMatched / model.TotalRowsInSql * 100).toFixed(2) : 100)}% תאימות</td></tr>
                    <tr><td>הפרשי ערכים</td><td style="color: red; font-weight: bold;">${model.TotalDiscrepancyRows}</td><td>${model.DiscrepancyPatterns.length} תבניות</td></tr>
                    <tr><td>פערי שלמות</td><td style="color: orange; font-weight: bold;">${model.DataIntegrityGaps.length}</td><td>ערך מול ריק/אפס</td></tr>
                </table>
            `;

            if (model.DiscrepancyPatterns.length > 0) {
                model.DiscrepancyPatterns.forEach((p, idx) => {
                    html += `
                        <h3>תבנית ${idx + 1}: ${p.PatternDescription}</h3>
                        <p><strong>כמות שורות:</strong> ${p.Count} | <strong>מפתחות לדוגמה:</strong> <span class="mono">${p.ExampleKeys.join(" | ")}</span></p>
                        <table>
                            <thead><tr><th>שם שדה</th><th>ערך במקור</th><th>ערך ביעד</th></tr></thead>
                            <tbody>
                    `;
                    p.Fields.forEach(f => {
                        html += `<tr><td class="mono">${f.FieldName}</td><td class="mono" style="color:red;">${f.SqlValue}</td><td class="mono" style="color:red;">${f.OracleValue}</td></tr>`;
                    });
                    html += `</tbody></table>`;
                });
            }

            if (model.DataIntegrityGaps.length > 0) {
                html += `
                    <h3>פערי שלמות נתונים (${model.DataIntegrityGaps.length})</h3>
                    <table>
                        <thead><tr><th>ערך מפתח</th><th>שם שדה</th><th>צד עם ערך</th><th>הערך</th></tr></thead>
                        <tbody>
                `;
                model.DataIntegrityGaps.forEach(g => {
                    html += `<tr><td class="mono">${g.KeyValue}</td><td>${g.FieldName}</td><td>${g.PresentSide === 'Source' ? 'מקור' : 'יעד'}</td><td class="mono" style="color:orange;">${g.PresentValue}</td></tr>`;
                });
                html += `</tbody></table>`;
            }

            html += `</body></html>`;

            const blob = new Blob(["\uFEFF" + html], { type: "application/msword" });
            const link = document.createElement("a");
            link.href = URL.createObjectURL(blob);
            link.download = `QA_Report_${model.SqlTable}_vs_${model.OracleTable}.doc`;
            link.click();
        }
    </script>
}
