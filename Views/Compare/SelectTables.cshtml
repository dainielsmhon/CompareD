@model CompareD.Controllers.TableSelectionViewModel

@* הגדרת כותרת הדף — שלב 2: בחירת טבלה או תצוגה *@
@{
    ViewData["Title"] = "שלב 2 — בחירת טבלאות";
}

@* ===== מחוון שלבים (Step Indicator) — שלב 2 פעיל ===== *@
<div class="glass-card mb-5 py-3 px-4" id="step-indicator-bar">
    <div class="d-flex justify-content-center align-items-center gap-2 flex-wrap" id="step-indicator-items">
        @* שלב 1 — הושלם *@
        <span class="badge bg-success/20 text-success px-3 py-2 fs-6 border border-success/30" id="step-1-badge">✓ חיבור</span>
        <span class="text-secondary">→</span>
        @* שלב 2 — פעיל כרגע *@
        <span class="badge px-3 py-2 fs-6" style="background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary)); color: #fff;" id="step-2-badge">2. בחירת טבלה</span>
        <span class="text-secondary">→</span>
        @* שלב 3 — טרם הגענו *@
        <span class="badge bg-dark text-secondary px-3 py-2 fs-6 border border-white/10" id="step-3-badge">3. סקירת סכמה</span>
        <span class="text-secondary">→</span>
        @* שלב 4 — טרם הגענו *@
        <span class="badge bg-dark text-secondary px-3 py-2 fs-6 border border-white/10" id="step-4-badge">4. בדיקות מקדימות</span>
        <span class="text-secondary">→</span>
        @* שלב 5 — טרם הגענו *@
        <span class="badge bg-dark text-secondary px-3 py-2 fs-6 border border-white/10" id="step-5-badge">5. השוואה</span>
        <span class="text-secondary">→</span>
        @* שלב 6 — טרם הגענו *@
        <span class="badge bg-dark text-secondary px-3 py-2 fs-6 border border-white/10" id="step-6-badge">6. דוח תוצאות</span>
    </div>
</div>

@* ===== כותרת הדף המרכזית לשלב בחירת הטבלאות ===== *@
<div class="text-center mb-5" id="select-tables-header">
    <h1 class="display-4 text-gradient mb-3" id="select-title">בחירת טבלאות ותצוגות להשוואה</h1>
    <p class="lead text-secondary fs-5" id="select-description">
        החיבור לשני מסדי הנתונים בוצע בהצלחה! כעת בחרו את הטבלאות או התצוגות (Views) שברצונכם להשוות — אחת מכל צד.
    </p>
</div>

@* ===== טופס הגשת הבחירה — שולח לפעולת SelectFields בבקר Compare ===== *@
<form id="select-tables-form" method="post" asp-controller="Compare" asp-action="SelectFields">
    @* פריסת בנטו גריד — כרטיס לכל צד *@
    <div class="bento-grid mb-5" id="tables-selection-grid">
        
        @* ===== כרטיס צד א׳ — SQL Server — בחירת טבלת מקור ===== *@
        <div class="glass-card" id="sql-tables-card">
            @* כותרת הכרטיס עם זיהוי הצד *@
            <h2 class="h4 text-gradient mb-2" id="sql-tables-title">צד א׳ — מקור</h2>
            <p class="text-secondary small mb-3" id="sql-tables-subtitle">SQL Server</p>
            @* תיבת חיפוש מהיר — מסננת את רשימת הטבלאות בזמן אמת בצד הלקוח *@
            <div class="mb-3">
                <label for="sql-search-input" class="form-label text-secondary small" id="sql-search-label">חיפוש מהיר</label>
                <input type="text" class="form-control form-input-glass text-light w-100" id="sql-search-input" placeholder="הקלידו שם טבלה או תצוגה לסינון..." autocomplete="off" />
            </div>
            @* תיבת בחירת הטבלה/תצוגה מתוך הרשימה שנשלפה מהמסד *@
            <div class="mb-3">
                <label for="sql-table-select" class="form-label text-secondary fs-6" id="sql-table-select-label">בחרו טבלה או תצוגה</label>
                <select class="form-select form-input-glass text-light w-100" id="sql-table-select" name="sqlTable" required>
                    <option value="" disabled selected>-- בחרו טבלה או תצוגה --</option>
                    @* לולאה על כל הטבלאות והתצוגות שנשלפו מ-SQL Server *@
                    @foreach (var table in Model.SqlTables)
                    {
                        @* הצגת שם הטבלה עם סוג האובייקט בסוגריים *@
                        <option value="@table.Name">@table.Name (@(table.Type == "VIEW" ? "תצוגה" : "טבלה"))</option>
                    }
                </select>
            </div>
            @* תצוגת סיכום כמות האובייקטים שנמצאו — מידע מהיר למשתמש *@
            <div class="text-secondary small" id="sql-count-info">
                נמצאו <strong class="text-light">@Model.SqlTables.Count</strong> טבלאות ותצוגות זמינות.
            </div>
        </div>

        @* ===== כרטיס צד ב׳ — Oracle — בחירת טבלת יעד ===== *@
        <div class="glass-card" id="oracle-tables-card">
            @* כותרת הכרטיס עם זיהוי הצד *@
            <h2 class="h4 text-gradient mb-2" id="oracle-tables-title">צד ב׳ — יעד</h2>
            <p class="text-secondary small mb-3" id="oracle-tables-subtitle">Oracle Database</p>
            @* תיבת חיפוש מהיר — מסננת את רשימת הטבלאות בזמן אמת בצד הלקוח *@
            <div class="mb-3">
                <label for="oracle-search-input" class="form-label text-secondary small" id="oracle-search-label">חיפוש מהיר</label>
                <input type="text" class="form-control form-input-glass text-light w-100" id="oracle-search-input" placeholder="הקלידו שם טבלה או תצוגה לסינון..." autocomplete="off" />
            </div>
            @* תיבת בחירת הטבלה/תצוגה מתוך הרשימה שנשלפה מהמסד *@
            <div class="mb-3">
                <label for="oracle-table-select" class="form-label text-secondary fs-6" id="oracle-table-select-label">בחרו טבלה או תצוגה</label>
                <select class="form-select form-input-glass text-light w-100" id="oracle-table-select" name="oracleTable" required>
                    <option value="" disabled selected>-- בחרו טבלה או תצוגה --</option>
                    @* לולאה על כל הטבלאות והתצוגות שנשלפו מ-Oracle *@
                    @foreach (var table in Model.OracleTables)
                    {
                        @* הצגת שם הטבלה עם סוג האובייקט בסוגריים *@
                        <option value="@table.Name">@table.Name (@(table.Type == "VIEW" ? "תצוגה" : "טבלה"))</option>
                    }
                </select>
            </div>
            @* תצוגת סיכום כמות האובייקטים שנמצאו — מידע מהיר למשתמש *@
            <div class="text-secondary small" id="oracle-count-info">
                נמצאו <strong class="text-light">@Model.OracleTables.Count</strong> טבלאות ותצוגות זמינות.
            </div>
        </div>

    </div>

    @* ===== כפתור המשך לשלב הבא (סקירת סכמה) ===== *@
    <div class="text-center" id="action-button-container">
        <button type="submit" class="btn-glow btn-lg px-5 py-3 fs-5" id="btn-proceed-schema">
            המשך לסקירת סכמה
        </button>
    </div>
</form>

@* ===== סקריפטים לסינון תיבות הבחירה בצד הלקוח (Client-Side Filtering) ===== *@
@section Scripts {
    <script>
        // האזנה לאירוע טעינת הדף במלואו לפני הפעלת הלוגיקה
        document.addEventListener("DOMContentLoaded", function() {
            // שמירת רשימת האופציות המקורית של צד א׳ (ללא אופציית ברירת המחדל הריקה)
            const sqlSelect = document.getElementById("sql-table-select");
            const sqlOptions = Array.from(sqlSelect.options).filter(o => o.value !== "");

            // שמירת רשימת האופציות המקורית של צד ב׳ (ללא אופציית ברירת המחדל הריקה)
            const oracleSelect = document.getElementById("oracle-table-select");
            const oracleOptions = Array.from(oracleSelect.options).filter(o => o.value !== "");

            // פונקציית עזר לסינון תיבות הבחירה — מחפשת טקסט חלקי בכל אופציה
            function filterDropdown(searchInput, selectElement, originalOptions) {
                // המרת מחרוזת החיפוש לאותיות קטנות וניקוי רווחים מיותרים
                const query = searchInput.value.toLowerCase().trim();
                // איפוס תיבת הבחירה והשארת כותרת ברירת המחדל בלבד
                selectElement.innerHTML = '<option value="" disabled selected>-- בחרו טבלה או תצוגה --</option>';
                
                // סינון הרשימה המקורית בהתאם למילת החיפוש
                const filtered = originalOptions.filter(o => o.text.toLowerCase().includes(query));
                
                // הוספת האופציות המסוננות בחזרה לתיבת הבחירה
                filtered.forEach(o => {
                    const newOpt = document.createElement("option");
                    newOpt.value = o.value;
                    newOpt.text = o.text;
                    selectElement.appendChild(newOpt);
                });
            }

            // הפעלת מאזין אירועים עבור קלט חיפוש בצד א׳ — מסנן בזמן אמת
            document.getElementById("sql-search-input").addEventListener("input", function() {
                filterDropdown(this, sqlSelect, sqlOptions);
            });

            // הפעלת מאזין אירועים עבור קלט חיפוש בצד ב׳ — מסנן בזמן אמת
            document.getElementById("oracle-search-input").addEventListener("input", function() {
                filterDropdown(this, oracleSelect, oracleOptions);
            });
        });
    </script>
}
