@model CompareD.Controllers.FieldMappingViewModel

@{
    ViewData["Title"] = "מיפוי שדות";
}

@* כותרת הדף המרכזית למסך מיפוי שדות *@
<div class="text-center mb-5" id="mapping-header">
    <h1 class="display-4 text-gradient mb-3" id="mapping-title">הגדרת מיפוי שדות</h1>
    <p class="lead text-secondary fs-5" id="mapping-description">
        בחרו בין השוואה אוטומטית מלאה של כל השדות בעלי שמות זהים לבין הגדרת מיפוי ידני מותאם אישית.
    </p>
    @* תצוגה מקדימה קטנה של הטבלאות הנבחרות *@
    <div class="d-flex justify-content-center gap-3 mt-3" id="selected-tables-preview">
        <span class="badge bg-primary px-3 py-2 fs-6" id="badge-sql">מקור: @Model.SqlTable</span>
        <span class="badge bg-secondary px-3 py-2 fs-6" id="badge-oracle">יעד: @Model.OracleTable</span>
    </div>
</div>

@* טופס הגשת תצורת המיפוי והרצת ההשוואה *@
<form id="fields-mapping-form" method="post" asp-controller="Compare" asp-action="CompareData">
    @* שדות מוסתרים המכילים את שמות הטבלאות לצורך שליחה בטופס *@
    <input type="hidden" name="sqlTable" value="@Model.SqlTable" />
    <input type="hidden" name="oracleTable" value="@Model.OracleTable" />
    @* שדה מוסתר לקביעת סוג המיפוי (Auto או Manual) *@
    <input type="hidden" id="mapping-mode-input" name="mappingMode" value="Auto" />

    @* פריסת בנטו גריד לבחירת מצב המיפוי (אוטומטי או ידני) *@
    <div class="bento-grid mb-5" id="mapping-options-grid">
        
        @* כרטיס אפשרות א - השוואה אוטומטית מלאה *@
        <div class="glass-card text-center cursor-pointer active-option-card" id="option-auto-card" style="border-color: var(--accent-primary) !important;">
            <h2 class="h4 text-gradient mb-3" id="auto-title">אפשרות א: השוואה אוטומטית מלאה</h2>
            <p class="text-secondary small mb-0" id="auto-desc">
                המערכת תמפה ותשווה באופן אוטומטי את כל העמודות בעלות שמות זהים בין טבלת המקור לטבלת היעד.
            </p>
        </div>

        @* כרטיס אפשרות ב - מיפוי ידני מותאם אישית *@
        <div class="glass-card text-center cursor-pointer" id="option-manual-card">
            <h2 class="h4 text-gradient mb-3" id="manual-title">אפשרות ב: מיפוי ידני מותאם אישית</h2>
            <p class="text-secondary small mb-0" id="manual-desc">
                הגדירו בעצמכם אילו שדות ישמשו כמפתח ההתאמה (Key Fields) ואילו שדות ערך יש להשוות ביניהם.
            </p>
        </div>

    </div>

    @* אזור מיפוי שדות ידני - מוסתר כברירת מחדל ומוצג רק בבחירת אפשרות ב *@
    <div class="glass-card mb-5 d-none" id="manual-mapping-container">
        <div class="d-flex justify-content-between align-items-center mb-4" id="manual-mapping-header-actions">
            <h3 class="h4 text-gradient mb-0" id="manual-builder-title">בקרת מיפוי שדות ידנית</h3>
            @* כפתור הוספת שורה חדשה מעוצב עם מעבר חלק *@
            <button type="button" class="btn btn-outline-primary transition-all rounded-pill px-4" id="btn-add-row-mapping">
                + הוסף שדה למיפוי
            </button>
        </div>

        @* טבלת המיפוי הידני *@
        <div class="table-responsive" id="mapping-table-wrapper">
            <table class="table table-dark table-borderless align-middle" id="mapping-table">
                <thead>
                    <tr class="text-secondary small">
                        <th style="width: 35%;">שדה מקור (SQL Server)</th>
                        <th style="width: 35%;">שדה יעד (Oracle)</th>
                        <th style="width: 20%;">תפקיד השדה</th>
                        <th style="width: 10%;" class="text-center">פעולות</th>
                    </tr>
                </thead>
                <tbody id="mapping-rows-body">
                    @* שורות המיפוי יתווספו כאן באופן דינמי באמצעות JavaScript *@
                </tbody>
            </table>
        </div>
        
        @* הודעת הסבר מקדימה למצב שבו אין עדיין שורות מיפוי *@
        <div class="text-center py-4 text-secondary" id="empty-rows-message">
            לחצו על הכפתור למעלה כדי להוסיף שדה חדש למיפוי.
        </div>
    </div>

    @* הגדרת שדה הגבלת רשומות בעיצוב Pro Max *@
    <div class="glass-card mb-5 text-center" id="limit-config-container" style="max-width: 450px; margin: 0 auto;">
        <label for="max-rows-input" class="form-label text-secondary fs-6 fw-bold" id="max-rows-label">הגבלת כמות רשומות לטעינה (Max Rows)</label>
        <input type="number" class="form-control form-input-glass text-center text-light mx-auto" id="max-rows-input" name="maxRows" value="1000" min="1" required style="max-width: 200px;" />
        <span class="text-secondary small d-block mt-2">הזנת ערך זה מונעת עומס על מסדי הנתונים ומספקת שליטה מלאה בטעינה.</span>
    </div>

    @* אזור כפתור ההרצה הראשי המרכזי *@
    <div class="text-center" id="action-button-container">
        <button type="submit" class="btn-glow btn-lg px-5 py-3 fs-5" id="btn-run-comparison">
            הרץ השוואת נתונים
        </button>
    </div>
</form>

@section Scripts {
    <script>
        // האזנה לטעינת הדף במלואו
        document.addEventListener("DOMContentLoaded", function() {
            // קבלת העמודות של המקור והיעד כרשימות JavaScript מהשרת
            const sqlColumns = @Json.Serialize(Model.SqlColumns);
            const oracleColumns = @Json.Serialize(Model.OracleColumns);

            // משתני אלמנטים לממשק
            const optAutoCard = document.getElementById("option-auto-card");
            const optManualCard = document.getElementById("option-manual-card");
            const mappingModeInput = document.getElementById("mapping-mode-input");
            const manualContainer = document.getElementById("manual-mapping-container");
            const rowsBody = document.getElementById("mapping-rows-body");
            const emptyMsg = document.getElementById("empty-rows-message");
            const btnAddRow = document.getElementById("btn-add-row-mapping");

            // פונקציית מעבר בין אפשרות א לאפשרות ב
            function selectMappingMode(mode) {
                mappingModeInput.value = mode;
                if (mode === "Auto") {
                    optAutoCard.classList.add("active-option-card");
                    optAutoCard.style.borderColor = "var(--accent-primary)";
                    optManualCard.classList.remove("active-option-card");
                    optManualCard.style.borderColor = "var(--border-color)";
                    manualContainer.classList.add("d-none");
                } else {
                    optManualCard.classList.add("active-option-card");
                    optManualCard.style.borderColor = "var(--accent-primary)";
                    optAutoCard.classList.remove("active-option-card");
                    optAutoCard.style.borderColor = "var(--border-color)";
                    manualContainer.classList.remove("d-none");
                    
                    // הוספת שורה ראשונה באופן אוטומטי לנוחות המשתמש
                    if (rowsBody.children.length === 0) {
                        addNewMappingRow();
                    }
                }
            }

            // האזנה ללחיצה על כרטיס השוואה אוטומטית
            optAutoCard.addEventListener("click", function() {
                selectMappingMode("Auto");
            });

            // האזנה ללחיצה על כרטיס מיפוי ידני
            optManualCard.addEventListener("click", function() {
                selectMappingMode("Manual");
            });

            // פונקציה להוספת שורת מיפוי חדשה
            function addNewMappingRow() {
                // הסתרת הודעת "אין שדות"
                emptyMsg.classList.add("d-none");

                // יצירת שורת טבלה חדשה
                const tr = document.createElement("tr");
                tr.className = "mapping-row-item";

                // יצירת עמודת שדה מקור (SQL Server)
                let sqlSelectOptions = sqlColumns.map(c => `<option value="${c}">${c}</option>`).join("");
                const tdSource = document.createElement("td");
                tdSource.innerHTML = `
                    <select class="form-select form-input-glass text-light w-100" name="sourceFields" required>
                        <option value="" disabled selected>-- בחרו שדה מקור --</option>
                        ${sqlSelectOptions}
                    </select>
                `;

                // יצירת עמודת שדה יעד (Oracle)
                let oracleSelectOptions = oracleColumns.map(c => `<option value="${c}">${c}</option>`).join("");
                const tdTarget = document.createElement("td");
                tdTarget.innerHTML = `
                    <select class="form-select form-input-glass text-light w-100" name="targetFields" required>
                        <option value="" disabled selected>-- בחרו שדה יעד --</option>
                        ${oracleSelectOptions}
                    </select>
                `;

                // יצירת עמודת תפקיד השדה (מפתח או השוואה)
                const tdRole = document.createElement("td");
                tdRole.innerHTML = `
                    <select class="form-select form-input-glass text-light w-100" name="fieldRoles" required>
                        <option value="Compare" selected>שדה להשוואה</option>
                        <option value="Key">שדה מפתח</option>
                    </select>
                `;

                // יצירת עמודת כפתור מחיקה
                const tdDelete = document.createElement("td");
                tdDelete.className = "text-center";
                tdDelete.innerHTML = `
                    <button type="button" class="btn btn-outline-danger btn-sm rounded-circle p-2" style="width: 36px; height: 36px; line-height: 1;" title="מחק שורה">✕</button>
                `;

                // הגדרת פעולת כפתור המחיקה
                tdDelete.querySelector("button").addEventListener("click", function() {
                    tr.remove();
                    if (rowsBody.children.length === 0) {
                        emptyMsg.classList.remove("d-none");
                    }
                });

                // הרכבת השורה וחיבורה לטבלה
                tr.appendChild(tdSource);
                tr.appendChild(tdTarget);
                tr.appendChild(tdRole);
                tr.appendChild(tdDelete);
                rowsBody.appendChild(tr);
            }

            // האזנה ללחיצה על כפתור הוספת שורה
            btnAddRow.addEventListener("click", addNewMappingRow);
        });
    </script>
}
