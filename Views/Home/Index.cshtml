@model CompareD.Controllers.HomeViewModel
@* הגדרת כותרת הדף לטובת כותרת ה-Title ב-Layout *@
@{
    ViewData["Title"] = "הגדרת חיבורים";
}

@* מיכל ראשי לדף הבית הכולל כותרת ואזור הגדרת חיבורים *@
<div class="text-center mb-5" id="home-welcome-header">
    @* כותרת ראשית מעוצבת באמצעות גרדיאנט טקסט מרהיב *@
    <h1 class="display-4 text-gradient mb-3" id="main-landing-title">הגדרת חיבורי מסדי נתונים</h1>
    @* תיאור קצר וממוקד מתחת לכותרת הראשית *@
    <p class="lead text-secondary fs-5" id="main-landing-description">
        הזינו את מחרוזות החיבור עבור שני מסדי הנתונים כדי לבדוק קישוריות ולהביא את רשימת הטבלאות.
    </p>
</div>

@* הצגת הודעת שגיאה מעוצבת בעיצוב Pro Max במידה וההתחברות נכשלה *@
@if (TempData["ErrorMessage"] != null)
{
    <div class="glass-card mb-5" style="border-color: rgba(239, 68, 68, 0.3) !important;" id="error-message-box">
        <div class="d-flex align-items-center justify-content-center gap-3">
            @* סימן שגיאה מובנה ללא שימוש באימוג'י *@
            <span class="text-danger fw-bold fs-4" id="error-icon" style="user-select: none;">✕</span>
            <div class="text-start">
                <h2 class="h6 mb-1 text-danger fw-bold" id="error-title">נכשל ניסיון ההתחברות למסדי הנתונים</h2>
                <p class="mb-0 text-secondary small" id="error-details">@TempData["ErrorMessage"]</p>
            </div>
        </div>
    </div>
}

@* טופס הגדרת החיבורים וההשוואה *@
<form id="compare-config-form" method="post" asp-controller="Compare" asp-action="Connect">
    @* פריסת Bento Grid הכוללת את כרטיסי הגדרות החיבורים למסדי הנתונים *@
    <div class="bento-grid mb-5" id="db-config-grid">
        
        @* כרטיס הגדרות חיבור למסד הנתונים SQL Server *@
        <div class="glass-card" id="sql-server-card">
            @* כותרת הכרטיס *@
            <h2 class="h4 text-gradient mb-4" id="sql-card-title">Legacy SQL Server</h2>
            @* תיבת בחירה עבור פרופיל חיבור *@
            <div class="mb-3">
                <label for="sql-profile-select" class="form-label text-secondary fs-6" id="sql-profile-select-label">בחרו פרופיל חיבור</label>
                <select class="form-select form-input-glass text-light w-100" id="sql-profile-select" name="sqlProfileName" required>
                    <option value="" disabled selected>-- בחרו פרופיל SQL --</option>
                    @foreach (var name in Model.SqlProfileNames)
                    {
                        if (name == Model.SelectedSqlProfile)
                        {
                            <option value="@name" selected>@name</option>
                        }
                        else
                        {
                            <option value="@name">@name</option>
                        }
                    }
                </select>
            </div>
        </div>

        @* כרטיס הגדרות חיבור למסד הנתונים Oracle *@
        <div class="glass-card" id="oracle-card">
            @* כותרת הכרטיס *@
            <h2 class="h4 text-gradient mb-4" id="oracle-card-title">New Oracle Database</h2>
            @* תיבת בחירה עבור פרופיל חיבור *@
            <div class="mb-3">
                <label for="oracle-profile-select" class="form-label text-secondary fs-6" id="oracle-profile-select-label">בחרו פרופיל חיבור</label>
                <select class="form-select form-input-glass text-light w-100" id="oracle-profile-select" name="oracleProfileName" required>
                    <option value="" disabled selected>-- בחרו פרופיל Oracle --</option>
                    @foreach (var name in Model.OracleProfileNames)
                    {
                        if (name == Model.SelectedOracleProfile)
                        {
                            <option value="@name" selected>@name</option>
                        }
                        else
                        {
                            <option value="@name">@name</option>
                        }
                    }
                </select>
            </div>
        </div>

    </div>

    @* אזור כפתור ההרצה הראשי המרכזי *@
    <div class="text-center" id="action-button-container">
        @* כפתור ביצוע ההשוואה מעוצב עם אפקט זוהר מתקדם ומעבר חלק *@
        <button type="submit" class="btn-glow btn-lg px-5 py-3 fs-5" id="btn-start-compare">
            התחבר והבא טבלאות
        </button>
    </div>
</form>
