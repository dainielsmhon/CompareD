{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "localhost;127.0.0.1;[::1]",
  "FileLimits": {
    "MaxPerFileMb": 50,
    "MaxTotalRequestMb": 105
  },
  "AdminSettings": {
    "AuthorizedUsers": [
      "DOMAIN\\authorized-username-1",
      "DOMAIN\\authorized-username-2",
      "DESKTOP-NAME\\local-developer-account"
    ]
  }
}
